# --- Fathom ---
# Create at the user level in Fathom settings (needs a plan with API access).
FATHOM_API_KEY=

# --- Email (SendGrid) ---
# 1. Create a SendGrid account (sendgrid.com) and generate an API key
#    (Settings -> API Keys -> Create API Key).
# 2. Add and verify a sender domain (Settings -> Sender Authentication) and set
#    MAIL_FROM to an address on that domain, e.g. notes@yourdomain.com
SENDGRID_API_KEY=
MAIL_FROM=notes@yourdomain.com
# Optional friendly from-name shown in inboxes.
MAIL_FROM_NAME=Meeting Dispatch

# --- Recipients ---
# Comma-separated. These prefill the recipient list in the app (still editable).
# Tip: while testing, set this to your OWN email first.
RECIPIENTS=hassan@example.com,faisal@example.com
