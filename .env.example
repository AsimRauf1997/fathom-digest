# --- Fathom ---
# Create at the user level in Fathom settings (needs a plan with API access).
FATHOM_API_KEY=

# --- Email (Resend) ---
# 1. Create a Resend account (resend.com) and an API key (API Keys -> Create).
# 2. Verify a sending domain (Domains -> Add Domain) and set MAIL_FROM to an
#    address on it, e.g. notes@yourdomain.com.
#    For quick testing without a domain, use MAIL_FROM=onboarding@resend.dev
#    (Resend's test sender — only delivers to your own account email).
RESEND_API_KEY=
MAIL_FROM=notes@yourdomain.com
# Optional friendly from-name shown in inboxes.
MAIL_FROM_NAME=Meeting Dispatch

# --- Recipients ---
# Comma-separated. These prefill the recipient list in the app (still editable).
# Tip: while testing, set this to your OWN email first.
RECIPIENTS=hassan@example.com,faisal@example.com
