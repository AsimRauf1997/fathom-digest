# --- Database (Neon Postgres + Drizzle) ---
# Pooled connection string from your Neon project (Dashboard -> Connection
# Details -> "Pooled connection"). Used by lib/db/index.ts and drizzle.config.ts.
DATABASE_URL=

# --- Auth (Clerk) ---
# Dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Dashboard -> Webhooks -> Signing Secret, for app/api/webhooks/clerk/route.ts.
CLERK_WEBHOOK_SECRET=
# Custom sign-in/up pages (this app uses its own UI, not Clerk's hosted pages).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
# Used as the base URL for Clerk invitation links and accept-invite links.
NEXT_PUBLIC_SITE_URL=
# Google OAuth is configured in the Clerk Dashboard (User & Authentication ->
# Social Connections -> Google), not read directly by this app.

# --- Encryption (application-level, replaces Supabase pgcrypto) ---
# 32-byte key (base64) for AES-256-GCM encryption of each team's Fathom API
# key (lib/crypto/fathom-key.ts). Server-only. Generate with:
#   openssl rand -base64 32
# Rotating requires re-encrypting all existing teams.fathom_api_key_enc
# values with the new key BEFORE swapping this env var.
FATHOM_KEY_ENCRYPTION_KEY=

# --- Email (SendGrid) ---
# 1. Create a SendGrid account (sendgrid.com) and generate an API key
#    (Settings -> API Keys -> Create API Key).
# 2. Add and verify a sender domain (Settings -> Sender Authentication) and set
#    MAIL_FROM to an address on that domain, e.g. notes@yourdomain.com
SENDGRID_API_KEY=
MAIL_FROM=notes@yourdomain.com
# Optional friendly from-name shown in inboxes.
MAIL_FROM_NAME=Meeting Dispatch
