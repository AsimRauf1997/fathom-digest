# --- Supabase ---
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key. Server-only — NEVER expose via NEXT_PUBLIC_. Used for the
# admin client (lib/supabase/admin.ts) and team invites.
SUPABASE_SERVICE_ROLE_KEY=
# Used as the base URL for invite redirect links sent by Supabase Auth.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Encryption ---
# Passphrase for pgcrypto pgp_sym_encrypt/decrypt of each team's Fathom API
# key. Server-only. Generate with: openssl rand -base64 32
# Rotating this requires re-encrypting all existing keys with the new value
# BEFORE swapping the env var — see supabase/migrations/0001_init.sql.
SUPABASE_DB_ENCRYPTION_KEY=

# Google OAuth is configured in the Supabase dashboard (Authentication ->
# Providers -> Google), not read directly by this app.

# --- Email (SendGrid) ---
# 1. Create a SendGrid account (sendgrid.com) and generate an API key
#    (Settings -> API Keys -> Create API Key).
# 2. Add and verify a sender domain (Settings -> Sender Authentication) and set
#    MAIL_FROM to an address on that domain, e.g. notes@yourdomain.com
SENDGRID_API_KEY=
MAIL_FROM=notes@yourdomain.com
# Optional friendly from-name shown in inboxes.
MAIL_FROM_NAME=Meeting Dispatch
